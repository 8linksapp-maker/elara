---
interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  heroImage?: string;
  category: string;
  readTime?: number;
}

const { title, description, slug, pubDate, heroImage, category, readTime } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('pt-BR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article class="post-card">
  <a href={`/blog/${slug}`} class="post-card-image">
    {heroImage ? (
      <img src={heroImage} alt={title} loading="lazy" />
    ) : (
      <div style="background: var(--ivory-dark); width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--border-dark)" stroke-width="1">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </div>
    )}
  </a>

  <div class="post-card-category">{category}</div>

  <h2 class="post-card-title">
    <a href={`/blog/${slug}`}>{title}</a>
  </h2>

  <p class="post-card-excerpt">{description}</p>

  <div class="post-card-footer">
    <time datetime={pubDate.toISOString()} class="post-card-date">{formattedDate}</time>
    {readTime && <span class="post-card-readtime">{readTime} min de leitura</span>}
  </div>
</article>
