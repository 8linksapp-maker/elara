---
const pathname = Astro.url.pathname;
const isActive = (path: string) => {
  if (path === '/') return pathname === '/';
  return pathname.startsWith(path);
};
---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <!-- Logo -->
    <a href="/" class="header-logo">
      Elara<span>.</span>
    </a>

    <!-- Nav -->
    <nav aria-label="Navegação principal">
      <ul class="header-nav">
        <li><a href="/" class={isActive('/') ? 'active' : ''}>Início</a></li>
        <li><a href="/blog" class={isActive('/blog') ? 'active' : ''}>Blog</a></li>
        <li><a href="/sobre" class={isActive('/sobre') ? 'active' : ''}>Sobre</a></li>
        <li><a href="/contato" class={isActive('/contato') ? 'active' : ''}>Contato</a></li>
      </ul>
    </nav>

    <!-- Actions -->
    <div class="header-actions">
      <button class="btn-search" aria-label="Buscar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
      <a href="/rss.xml" class="btn-rss">RSS</a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const onScroll = () => {
    header?.classList.toggle('scrolled', window.scrollY > 20);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
